# ── Global Signal — Environment Variables ──
# Copy this file to .env.local and fill in your keys

# Cesium Ion Access Token (free): https://ion.cesium.com — 75k tiles/month
# Required for satellite imagery globe
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# NASA API Key (free): https://api.nasa.gov — register for 1000 req/hr
# Falls back to DEMO_KEY (30 req/hr) if not set
NASA_API_KEY=

# NewsAPI Key (free): https://newsapi.org/register — 100 req/day
# If not set, the News tab shows a friendly setup message
NEWS_API_KEY=

# App name shown in the header
NEXT_PUBLIC_APP_NAME=Global Signal

# Vercel notes:
# - Set these in Project Settings > Environment Variables for Production/Preview.
# - Keep Root Directory as the repository root and Framework Preset as Next.js.
# - Do not commit .env.local or real secrets.
